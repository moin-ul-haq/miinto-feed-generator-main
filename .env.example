# Copy to .env and fill in. Never commit real secrets.
# Hosting for the generated feed (your own environment for the trial).
# Miinto pulls the feed over HTTPS with HTTP Basic Auth.

FEED_BASIC_AUTH_USER=changeme
FEED_BASIC_AUTH_PASS=changeme

# Where the generator writes the feed file.
FEED_OUTPUT_PATH=output/miinto_feed.tsv

# Public URL where the feed is reachable (point FAS at this for validation).
FEED_PUBLIC_URL=https://your-host.example.com/miinto_feed.tsv
